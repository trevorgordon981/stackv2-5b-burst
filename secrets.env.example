# Copy to secrets.env (which IS committed in this private repo so the box is zero-config).
# The only secret needed: a Tailscale auth key, so the rented box joins your tailnet and
# pulls data + the latest checkpoint from the NAS.
#
# Mint one at: https://login.tailscale.com/admin/settings/keys
#   - Reusable: ON   (so you can burst repeatedly)
#   - Ephemeral: ON  (device auto-removes when the box dies)
#   - Tags: tag:ci   (or similar; ensure your ACL lets that tag reach the NAS over SSH)
#   - Expiry: 30–90d (rotate when it lapses)
TS_AUTHKEY=tskey-auth-REPLACE_ME

# Optional overrides:
# NAS=batcloud        # NAS tailnet hostname/IP (must be reachable + SSH-allowed by ACL)
# SHARD_DIRS=8        # how many language shard-dirs to stage (scale to burst length)
